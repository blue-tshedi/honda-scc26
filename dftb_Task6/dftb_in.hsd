Geometry = GenFormat {
  <<< "water.gen"
}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1e-5

  MaxAngularMomentum {
    O = "p"
    H = "s"
  }

  SlaterKosterFiles = Type2FileNames {
    Prefix = "/home/honda/dftb_workspace/dftb_parameters/3ob-3-1/"
    Separator = "-"
    Suffix = ".skf"
  }
}

Options {
  WriteResultsTag = Yes
}

ParserOptions {
  ParserVersion = 7
}
